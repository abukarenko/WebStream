<Window x:Class="WebStream.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WebStream Radio" Height="620" Width="980" MinHeight="500" MinWidth="780"
        Background="{StaticResource Surface}" Foreground="White" WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="270" />
      <ColumnDefinition Width="24" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{StaticResource Panel}" CornerRadius="16" Padding="18">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="WEBSTREAM" FontWeight="Bold" FontSize="19" Foreground="{StaticResource Accent}" Margin="0,0,0,28" />
        <TextBlock DockPanel.Dock="Top" Text="БЫСТРЫЙ ВЫБОР" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10" />
        <ListBox x:Name="StationsList" DockPanel.Dock="Top" Background="Transparent" BorderThickness="0" Foreground="White"
                 SelectionChanged="StationsList_SelectionChanged" MaxHeight="150">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="8,8">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Description}" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,3,0,0" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock DockPanel.Dock="Top" Text="УСПЕШНО ЗАПУЩЕННЫЕ СТАНЦИИ" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold" Margin="0,20,0,10" />
        <ListBox x:Name="HistoryList" Background="Transparent" BorderThickness="0" Foreground="White"
                 SelectionChanged="HistoryList_SelectionChanged" ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="8,6">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding Description}" Foreground="{StaticResource Muted}" FontSize="12" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="18" />
          <ColumnDefinition Width="260" />
          <ColumnDefinition Width="18" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="СЕЙЧАС ИГРАЕТ" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold" />
          <TextBlock x:Name="StationNameText" Text="Выберите станцию" FontSize="28" FontWeight="SemiBold" Margin="0,8,0,0" />
        </StackPanel>
        <TextBox Grid.Column="2" x:Name="MetadataLogText" Height="116" IsReadOnly="True" AcceptsReturn="True"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                 Background="#101216" BorderBrush="#343C47" Foreground="{StaticResource Muted}" FontSize="11"
                 Padding="10" ToolTip="Все метаданные, полученные от станции" />
        <TextBlock Grid.Column="4" x:Name="StatusText" Text="ГОТОВО" Foreground="{StaticResource Accent}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
      </Grid>

      <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,28">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="230" />
          <ColumnDefinition Width="34" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="220" Height="220" CornerRadius="20" Background="#2B313A" HorizontalAlignment="Center">
          <Grid>
            <Image x:Name="ArtworkImage" Stretch="UniformToFill" Visibility="Collapsed" ImageFailed="ArtworkImage_ImageFailed" />
            <Grid x:Name="ArtworkPlaceholder">
              <Ellipse Width="164" Height="164" Fill="#343C47" />
              <TextBlock Text="♪" Foreground="{StaticResource Accent}" FontSize="104" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-10,0,0" />
            </Grid>
            <Border VerticalAlignment="Bottom" Background="#101216AA" CornerRadius="0,0,20,20" Padding="12,8">
              <TextBlock x:Name="ArtworkCaptionText" Text="ОБЛОЖКА СТАНЦИИ" TextAlignment="Center" FontWeight="Bold" FontSize="10" Foreground="White" />
            </Border>
          </Grid>
        </Border>
        <Border Grid.Column="2" Background="{StaticResource Panel}" CornerRadius="16" Padding="20">
          <StackPanel>
            <TextBlock Text="МЕТАДАННЫЕ ЭФИРА" Foreground="{StaticResource Accent}" FontSize="11" FontWeight="Bold" />
            <TextBlock x:Name="TrackText" Text="Добавьте URL радиопотока, чтобы начать" FontSize="21" FontWeight="SemiBold" Margin="0,10,0,20" TextWrapping="Wrap" />
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="145" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <Grid.RowDefinitions><RowDefinition Height="30" /><RowDefinition Height="30" /><RowDefinition Height="30" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
              <TextBlock Text="СТАНЦИЯ" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
              <TextBlock x:Name="MetaStationText" Grid.Column="1" Text="—" VerticalAlignment="Center" />
              <TextBlock Grid.Row="1" Text="ЖАНР / ОПИСАНИЕ" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
              <TextBlock x:Name="MetaDescriptionText" Grid.Row="1" Grid.Column="1" Text="—" VerticalAlignment="Center" />
              <TextBlock Grid.Row="2" Text="СТАТУС" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
              <TextBlock x:Name="MetaStatusText" Grid.Row="2" Grid.Column="1" Text="Готово к воспроизведению" VerticalAlignment="Center" />
              <TextBlock Grid.Row="3" Text="АДРЕС ПОТОКА" Foreground="{StaticResource Muted}" FontSize="11" FontWeight="Bold" Margin="0,8,0,0" />
              <TextBlock x:Name="MetaUrlText" Grid.Row="3" Grid.Column="1" Text="—" Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0" />
            </Grid>
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="2" Background="{StaticResource Panel}" CornerRadius="16" Padding="18">
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="12" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <TextBox x:Name="StreamUrlBox" VerticalContentAlignment="Center" ToolTip="URL потока: MP3, AAC или совместимый HTTP(S)-поток">
            <TextBox.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Вставить новый URL (заменить)" Click="PasteReplacementUrl_Click" />
                <MenuItem Header="Очистить поле" Click="ClearStreamUrl_Click" />
                <Separator />
                <MenuItem Header="Выделить всё" Click="SelectAllStreamUrl_Click" />
              </ContextMenu>
            </TextBox.ContextMenu>
          </TextBox>
          <Button Grid.Column="2" x:Name="PlayButton" Content="▶  Слушать" Background="{StaticResource Accent}" Foreground="#102018" Click="PlayButton_Click" />
          <Button Grid.Column="4" Content="■" ToolTip="Остановить" Click="StopButton_Click" />
        </Grid>
      </Border>
      <MediaElement x:Name="Player" LoadedBehavior="Manual" UnloadedBehavior="Stop" MediaOpened="Player_MediaOpened" MediaFailed="Player_MediaFailed" Visibility="Collapsed" />
    </Grid>
  </Grid>
</Window>
