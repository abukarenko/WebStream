<Application x:Class="WebStream.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="Surface" Color="#15171C" />
    <SolidColorBrush x:Key="Panel" Color="#20232A" />
    <SolidColorBrush x:Key="Accent" Color="#70E0AA" />
    <SolidColorBrush x:Key="Muted" Color="#A5ABB8" />
    <Style TargetType="Button">
      <Setter Property="Background" Value="#2A2F38" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#292D35" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#3D4451" />
      <Setter Property="Padding" Value="12,9" />
      <Setter Property="FontSize" Value="14" />
    </Style>
  </Application.Resources>
</Application>
